# Copy this file to `.streamlit/secrets.toml` locally, or set keys in
# Streamlit Cloud -> App Settings -> Secrets.
#
# Runtime behavior:
# - Local run: uses LOCAL_DATABASE_URL (default SQLite)
# - Cloud run: uses CLOUD_DATABASE_URL, then DATABASE_URL fallback

LOCAL_DATABASE_URL = "sqlite:///investment.db"
CLOUD_DATABASE_URL = "postgresql+psycopg2://postgres:password@db.example.supabase.co:5432/postgres"
DATABASE_URL = ""
# Optional: set password to enable login. Leave empty to disable login.
APP_PASSWORD = ""

GEMINI_API_KEY = "AIzaSyCNc-oDxaFSbNRxa0UCfSW6bUo0I2LbXRo"
DISCORD_WEBHOOK_URL = ""
FRED_API_KEY = ""
ESTAT_API_KEY = ""

# Optional for admin health page GitHub Actions logs
GITHUB_REPOSITORY = "owner/repo"
GITHUB_TOKEN = ""
