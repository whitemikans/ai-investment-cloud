# Local run (default: SQLite if unset)
LOCAL_DATABASE_URL=sqlite:///investment.db

# Cloud run (Streamlit Cloud / Supabase)
CLOUD_DATABASE_URL=postgresql+psycopg2://postgres:password@db.example.supabase.co:5432/postgres
# Backward-compatible key (cloud fallback)
DATABASE_URL=

# Optional: set password to enable login. Leave empty to disable login.
APP_PASSWORD=
GEMINI_API_KEY=
FRED_API_KEY=
ESTAT_API_KEY=
DISCORD_WEBHOOK_URL=
GITHUB_REPOSITORY=owner/repo
GITHUB_TOKEN=
